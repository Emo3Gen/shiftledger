# Supabase connection
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Server
PORT=3000

# API authentication
# Leave empty for dev mode (no auth)
API_KEY=your-secret-key-here

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_GENERAL=100
RATE_LIMIT_INGEST=30
